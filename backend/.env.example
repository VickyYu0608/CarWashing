MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=carwashing
# Optional: DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/carwashing

# Database backup (方案 D) — from backend/ directory:
#   python scripts/export_db.py          # -> backups/carwashing_YYYYMMDD_HHMMSS.sql + latest.sql
#   python scripts/import_db.py          # restore latest backup on a new machine
#   python scripts/import_db.py -f backups/carwashing_YYYYMMDD_HHMMSS.sql

# ── Email verification (registration) ─────────────────────────────────────
