# Server
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:8000
JWT_SECRET=change-me-in-production
PAYMENT_DEMO_MODE=true

# WeChat Pay (APP) — fill after merchant approval to enable live WeChat checkout
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
# Optional override; default is {PUBLIC_BASE_URL}/api/payments/wechat/notify
WECHAT_NOTIFY_URL=

# Alipay (APP) — fill after merchant approval to enable live Alipay checkout
ALIPAY_APP_ID=
# PEM private key content (use \n for newlines) or path via ALIPAY_PRIVATE_KEY_PATH
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
