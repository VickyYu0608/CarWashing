# Copy this file to secrets.properties and paste your Google Maps API key.
# secrets.properties is gitignored and will not be committed.
#
# Get a key: https://console.cloud.google.com/google/maps-apis/
# Enable: Maps SDK for Android, Geocoding API
google.maps.api.key=YOUR_GOOGLE_MAPS_API_KEY

# Optional: WeChat Open Platform app id for native WeChat Pay cashier.
# Also requires backend POST /api/payments/wechat/prepay to sign orders.
# wechat.app.id=wxYOURAPPID
